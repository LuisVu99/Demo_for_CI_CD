# ============================================================================
# LOCAL DEVELOPMENT ONLY - DO NOT COMMIT TO GITHUB
# ============================================================================
# Non-sensitive configuration (URLs - get from variables, not hardcoded)
# CI/CD uses GitHub environment variables instead
DEV_BASE_URL=https://demo.growcrm.io
STAGING_BASE_URL=https://staging.growcrm.io
PROD_BASE_URL=https://growcrm.io
base_url=https://www.automationexercise.com

# Sensitive credentials (for local testing)
# CI/CD uses GitHub secrets instead (see Settings > Secrets and variables > Actions)
ADMIN_EMAIL=your_admin_email@example.com
ADMIN_PASSWORD=your_admin_password
ADMIN_USERNAME=Admin Name
USER_FULL_NAME=User Full Name
USER_PASSWORD=your_user_password
USER_USERNAME=username
